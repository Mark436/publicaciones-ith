---
import {
  tarjetasResumen,
  publicacionesPorSemana,
  estadoActual,
  autoresTop,
  actividadReciente,
} from '@/constants/estadisticasSitio.ts'

// Cálculos hechos en build-time (Astro renderiza estático por defecto)
const alturaMaximaBarra = Math.max(
  ...publicacionesPorSemana.map((item) => item.publicadas + item.ocultas)
)

const anchoMaximoAutor = Math.max(...autoresTop.map((autor) => autor.publicaciones))

// Geometría de la dona (SVG), radio y circunferencia fijos
const radio = 60
const circunferencia = 2 * Math.PI * radio

let acumulado = 0
const segmentosDona = estadoActual.map((estado) => {
  const largo = (estado.porcentaje / 100) * circunferencia
  const segmento = {
    ...estado,
    largoTrazo: largo,
    espacioTrazo: circunferencia - largo,
    desplazamiento: circunferencia * 0.25 - acumulado, // inicia arriba (12 en punto)
  }
  acumulado += largo
  return segmento
})

const totalEstado = estadoActual.reduce((suma, estado) => suma + estado.valor, 0)

const colorTexto: Record<string, string> = {
  azul: 'text-blue-900',
  gris: 'text-slate-300',
  naranja: 'text-amber-500',
}

const colorFondo: Record<string, string> = {
  azul: 'bg-blue-900',
  gris: 'bg-slate-300',
  naranja: 'bg-amber-500',
}

const colorFondoSuave: Record<string, string> = {
  azul: 'bg-blue-100 text-blue-900',
  verde: 'bg-emerald-100 text-emerald-700',
  naranja: 'bg-orange-100 text-orange-700',
  morado: 'bg-violet-100 text-violet-700',
}
---

<section class="bg-slate-100 p-6">
  <header class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-blue-950">Estadísticas del sitio</h1>
      <p class="text-sm text-slate-500">Actividad de publicación · Actualizado: 4 jul 2026</p>
    </div>
    <div class="flex overflow-hidden rounded-lg border border-slate-200 bg-white text-sm">
      <button type="button" class="px-4 py-2 text-slate-500 hover:bg-slate-50" data-rango="7">7 días</button>
      <button type="button" class="bg-white px-4 py-2 font-semibold text-blue-950 shadow-inner" data-rango="30" aria-current="true">30 días</button>
      <button type="button" class="px-4 py-2 text-slate-500 hover:bg-slate-50" data-rango="90">3 meses</button>
      <button type="button" class="px-4 py-2 text-slate-500 hover:bg-slate-50" data-rango="365">1 año</button>
    </div>
  </header>

  <div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {tarjetasResumen.map((tarjeta) => (
      <article class="rounded-xl bg-white p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <span class={`flex h-10 w-10 items-center justify-center rounded-lg ${colorFondoSuave[tarjeta.colorIcono]}`} aria-hidden="true">
            {tarjeta.icono === 'documento' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                <path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" />
                <path d="M14 3v5h5" />
              </svg>
            )}
            {tarjeta.icono === 'lapiz' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                <path d="m16.5 3.5 4 4L8 20H4v-4Z" />
              </svg>
            )}
            {tarjeta.icono === 'persona' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                <circle cx="12" cy="8" r="4" />
                <path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
              </svg>
            )}
            {tarjeta.icono === 'imagen' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="m21 15-5-5-11 11" />
              </svg>
            )}
          </span>
          <span class="flex items-center gap-1 text-sm font-medium text-emerald-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-3 w-3">
              <path d="m5 15 7-7 7 7" />
            </svg>
            {tarjeta.cambio}
          </span>
        </div>
        <p class="text-3xl font-bold text-blue-950">{tarjeta.valor}</p>
        <p class="text-sm text-slate-500">{tarjeta.etiqueta}</p>
      </article>
    ))}
  </div>

  <div class="mb-6 grid grid-cols-1 gap-4 lg:grid-cols-3">
    <article class="rounded-xl bg-white p-6 shadow-sm lg:col-span-2">
      <h2 class="text-base font-semibold text-blue-950">Publicaciones por mes</h2>
      <p class="mb-6 text-sm text-slate-500">Enero – Julio 2026</p>

      <div class="mb-4 flex items-center gap-4 text-sm text-slate-500">
        <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-blue-900"></span>Publicadas</span>
        <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-slate-300"></span>Ocultadas</span>
      </div>

      <div class="flex items-end gap-6 border-l border-b border-slate-200 pl-2 pb-2" style="height: 220px">
        {publicacionesPorSemana.map((item) => (
          <div class="flex flex-1 flex-col items-center gap-2">
            <div class="flex h-[180px] w-full items-end gap-1">
              <div
                class="flex-1 rounded-t bg-blue-900"
                style={`height: ${(item.publicadas / alturaMaximaBarra) * 180}px`}
                title={`Publicadas: ${item.publicadas}`}
              >
              </div>
              {item.ocultas > 0 && (
                <div
                  class="flex-1 rounded-t bg-slate-300"
                  style={`height: ${(item.ocultas / alturaMaximaBarra) * 180}px`}
                  title={`Ocultadas: ${item.ocultas}`}
                >
                </div>
              )}
            </div>
            <span class="text-xs text-slate-500">{item.semana}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="rounded-xl bg-white p-6 shadow-sm">
      <h2 class="text-base font-semibold text-blue-950">Estado actual</h2>
      <p class="mb-6 text-sm text-slate-500">Distribución de publicaciones</p>

      <div class="mb-6 flex justify-center">
        <svg viewBox="0 0 160 160" class="h-40 w-40 -rotate-90">
          {segmentosDona.map((segmento) => (
            <circle
              cx="80"
              cy="80"
              r={radio}
              fill="none"
              stroke-width="18"
              class={colorTexto[segmento.color]}
              stroke="currentColor"
              stroke-dasharray={`${segmento.largoTrazo} ${segmento.espacioTrazo}`}
              stroke-dashoffset={segmento.desplazamiento}
            />
          ))}
        </svg>
      </div>

      <ul class="space-y-3 text-sm">
        {estadoActual.map((estado) => (
          <li class="flex items-center justify-between">
            <span class="flex items-center gap-2 text-slate-600">
              <span class={`h-2.5 w-2.5 rounded-full ${colorFondo[estado.color]}`}></span>
              {estado.nombre}
            </span>
            <span class="text-slate-500">
              <span class="font-semibold text-blue-950">{estado.valor}</span> {estado.porcentaje}%
            </span>
          </li>
        ))}
      </ul>
    </article>
  </div>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    <article class="rounded-xl bg-white p-6 shadow-sm">
      <h2 class="text-base font-semibold text-blue-950">Top autores</h2>
      <p class="mb-6 text-sm text-slate-500">Publicaciones por editor</p>

      <ul class="space-y-4">
        {autoresTop.map((autor) => (
          <li class="flex items-center gap-3">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue-900 text-xs font-semibold text-white">
              {autor.iniciales}
            </span>
            <span class="w-28 shrink-0 text-sm text-slate-700">{autor.nombre}</span>
            <span class="h-2 flex-1 overflow-hidden rounded-full bg-slate-100">
              <span
                class="block h-full rounded-full bg-blue-900"
                style={`width: ${(autor.publicaciones / anchoMaximoAutor) * 100}%`}
              >
              </span>
            </span>
            <span class="w-6 text-right text-sm text-slate-500">{autor.publicaciones}</span>
          </li>
        ))}
      </ul>
    </article>

    <article class="rounded-xl bg-white p-6 shadow-sm">
      <h2 class="text-base font-semibold text-blue-950">Actividad reciente</h2>
      <p class="mb-6 text-sm text-slate-500">Últimas acciones en el sistema</p>

      <ul class="space-y-4">
        {actividadReciente.map((evento) => (
          <li class="flex items-center gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
            <div class="flex-1">
              <p class="text-sm text-slate-700">{evento.titulo}</p>
            </div>
            <span class="text-xs text-slate-400">{evento.hora}</span>
          </li>
        ))}
      </ul>
    </article>
  </div>
</section>

<script>
  // Interactividad mínima: cambiar el rango activo visualmente (vanilla JS, sin frameworks)
  const botonesRango = document.querySelectorAll<HTMLButtonElement>('[data-rango]')

  const marcarActivo = (boton: HTMLButtonElement) => {
    botonesRango.forEach((btn) => {
      btn.classList.remove('bg-white', 'font-semibold', 'text-blue-950', 'shadow-inner')
      btn.classList.add('text-slate-500')
      btn.removeAttribute('aria-current')
    })
    boton.classList.add('bg-white', 'font-semibold', 'text-blue-950', 'shadow-inner')
    boton.classList.remove('text-slate-500')
    boton.setAttribute('aria-current', 'true')
  }

  botonesRango.forEach((boton) => {
    boton.addEventListener('click', () => marcarActivo(boton))
  })
</script>
